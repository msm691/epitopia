{
  "name": "polytopia-clone",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "shared",
    "engine",
    "server",
    "client"
  ],
  "scripts": {
    "dev": "npm run dev --workspace client",
    "dev:server": "npm run dev --workspace server",
    "start:server": "npm run start --workspace server",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -b shared engine server client",
    "build": "npm run build --workspace client"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "typescript": "^5.5.4",
    "vitest": "^2.0.5"
  }
}
